# ──────────────────────────────────────────────
# TradingJournalAnalyzer 后端环境变量配置
# ──────────────────────────────────────────────
# 复制本文件为 .env 并填入实际值：
#   cp .env.example .env
#
# .env 已在 .gitignore 中，不会被提交。
# ──────────────────────────────────────────────

# ===== 数据库 =====
# PostgreSQL 连接串，格式：postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tradelens

# ===== JWT 认证 =====
# JWT 签名密钥。开发环境可随意填写；生产环境（ENV=production）必须 >=32 字符且不能使用默认值
SECRET_KEY=dev-only-change-this-to-a-random-32-char-string
# JWT 算法（通常不需要改）
JWT_ALGORITHM=HS256
# Token 有效期（分钟），默认 480 = 8 小时
JWT_EXPIRE_MINUTES=480

# ===== AI 配置 =====
# AI 提供商：openai | claude | deepseek | openrouter
AI_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# --- Claude (Anthropic) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- 自定义 OpenAI 兼容端点（可选）---
# 当 AI_PROVIDER 不匹配上述提供商时，可通过 BASE_URL + MODEL 指向任意 OpenAI 兼容 API
BASE_URL=
MODEL=

# ===== 跨域 (CORS) =====
# 允许的前端来源，多个地址用逗号分隔。生产环境需替换为实际部署域名
CORS_ORIGINS=http://localhost:5173

# ===== 环境标识 =====
# 设为 production 时启用严格校验（SECRET_KEY 不可为默认值，长度 >=32）
ENV=development
